APP_NAME=Exam Crawler Local Test
APP_ENV=localtest
APP_HOST=127.0.0.1
APP_PORT=8001
DATABASE_URL=sqlite:///./data/testcrawl_localtest.db
ADMIN_API_KEY=local-test-key

CRAWL_TIMEOUT_SEC=20
CRAWL_MAX_SECTIONS_PER_PROVINCE=8
CRAWL_MAX_ARTICLES_PER_SECTION=20
CRAWL_REQUEST_DELAY_SEC=0.5
CRAWL_USE_BROWSER=true

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_WAIT_UNTIL=domcontentloaded
PLAYWRIGHT_TIMEOUT_MS=20000
PLAYWRIGHT_POST_LOAD_WAIT_MS=1000

BROWSER_USE_ENABLED=false
BROWSER_USE_MODEL=gpt-5-mini
BROWSER_USE_MAX_STEPS=6
BROWSER_USE_RESULT_LIMIT=6
BROWSER_USE_MIN_RESULTS_TRIGGER=2
OPENAI_API_KEY=
OPENAI_BASE_URL=

DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
AI_SEARCH_MODEL=deepseek-chat
AI_SEARCH_CANDIDATES=120
AI_SEARCH_LIMIT=20

AUTO_REFRESH_ENABLED=false
AUTO_REFRESH_HOUR=12
AUTO_REFRESH_MINUTE=0
AUTO_REFRESH_TIMEZONE=Asia/Shanghai
