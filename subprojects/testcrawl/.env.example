# LLM：DEEPSEEK_API_KEY / OPENAI_API_KEY 也可只写在仓库根目录的 .env（与主工作台共用），本文件可留空或作覆盖。
APP_NAME=Exam Crawler API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8001
DATABASE_URL=sqlite:///./data/testcrawl.db
ADMIN_API_KEY=change-this-api-key
CRAWL_TIMEOUT_SEC=20
CRAWL_MAX_SECTIONS_PER_PROVINCE=8
CRAWL_MAX_ARTICLES_PER_SECTION=20
CRAWL_REQUEST_DELAY_SEC=1.0
CRAWL_USE_BROWSER=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_WAIT_UNTIL=domcontentloaded
PLAYWRIGHT_TIMEOUT_MS=20000
PLAYWRIGHT_POST_LOAD_WAIT_MS=1000
BROWSER_USE_ENABLED=false
BROWSER_USE_MODEL=gpt-4.1-mini
BROWSER_USE_MAX_STEPS=8
BROWSER_USE_RESULT_LIMIT=8
BROWSER_USE_MIN_RESULTS_TRIGGER=3
OPENAI_API_KEY=
OPENAI_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
AI_SEARCH_MODEL=deepseek-chat
AI_SEARCH_CANDIDATES=120
AI_SEARCH_LIMIT=20
AUTO_REFRESH_ENABLED=true
AUTO_REFRESH_HOUR=12
AUTO_REFRESH_MINUTE=0
AUTO_REFRESH_TIMEZONE=Asia/Shanghai
